TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Chats that write to the bot are saved here and receive new-sale alerts (no admin chat id needed)
SALE_NOTIFY_SUBSCRIBER_CHATS_STATE=.sale_notify_subscriber_chats.json
# Comma-separated order.status values that count as “paid” for alerts (must match DB)
PAID_ORDER_NOTIFY_STATUSES=PAID,COMPLETED,DELIVERED
# Seconds between Supabase polls for new paid orders
PAID_ORDERS_POLL_SECONDS=20
# Max paid orders to load per poll (most recent first)
PAID_ORDERS_FETCH_LIMIT=200
# JSON file storing order UUIDs already notified (avoids duplicates after restart)
NOTIFIED_PAID_ORDERS_STATE=.notified_paid_order_ids.json
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_MODEL=qwen3.5-flash
# US Virginia (default). For intl keys: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
SUPABASE_STORAGE_BUCKET=images
SUPABASE_PRODUCTS_FOLDER=products
